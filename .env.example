# Harbor Environment Configuration
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# =============================================================================
# REQUIRED
# =============================================================================

# Secret key used to sign JWTs. Must be a strong random string.
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32

# bcrypt hash of the login password.
# Generate with:
#   docker run --rm harbor-backend python -c \
#     "from app.core.security import get_password_hash; print(get_password_hash('yourpassword'))"
# Or before the image is built:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
PASSWORD_HASH=

# =============================================================================
# AUTH
# =============================================================================

# JWT signing algorithm. HS256 is fine for single-node personal use.
JWT_ALGORITHM=HS256

# JWT expiry in minutes. Default is 7 days (10080).
# Set lower (e.g., 60) if you want sessions to expire more aggressively.
JWT_EXPIRE_MINUTES=10080

# =============================================================================
# DOCKER
# =============================================================================

# Path to the Docker socket. Default works for standard Linux Docker installs.
# For Docker Desktop on Mac/Windows (dev only): /var/run/docker.sock is tunneled.
# For rootless Docker: unix:///run/user/1000/docker.sock
DOCKER_SOCKET=unix:///var/run/docker.sock

# GID of the "docker" group on the host. The entrypoint adds the harbor user
# to this group so it can read the Docker socket without running as root.
# Find yours with: getent group docker | cut -d: -f3
DOCKER_GID=982

# =============================================================================
# DATABASE
# =============================================================================

# SQLite database path. Relative to the backend working directory.
# In Docker this is mounted at /app/data/harbor.db via the data volume.
DATABASE_URL=sqlite:///./data/harbor.db

# =============================================================================
# SERVICES
# =============================================================================

# Path to services.yml config file. Relative to the backend working directory.
# In Docker this is mounted at /app/services.yml via the volume mount.
SERVICES_CONFIG_PATH=./services.yml

# =============================================================================
# CORS (development only)
# =============================================================================

# Comma-separated list of allowed origins for CORS.
# In production, nginx serves frontend and backend on the same origin,
# so CORS is not needed. This is only used when running backend standalone.
# Example: http://localhost:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
