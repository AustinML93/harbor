# Normalize line endings to LF on commit, for cross-platform consistency.
# Files are stored as LF in the repo; git handles conversion on checkout.
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
