# =============================================================================
# Harbor .gitignore
# =============================================================================

# Environment / secrets
.env
.env.local
.env.*.local
!.env.example

# Services config (user-specific, not committed)
services.yml

# =============================================================================
# Python
# =============================================================================

# Virtual environments
.venv/
venv/
env/
ENV/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Distribution / packaging
.Python
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# Type checker
.mypy_cache/
.dmypy.json
.pytype/

# Jupyter
.ipynb_checkpoints

# =============================================================================
# SQLite
# =============================================================================

*.db
*.sqlite
*.sqlite3
backend/data/

# =============================================================================
# Node / Frontend
# =============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
frontend/dist/
frontend/build/
.vite/

# Coverage
coverage/

# TypeScript cache
*.tsbuildinfo

# =============================================================================
# Docker
# =============================================================================

# Don't ignore docker-compose.override.yml intentionally —
# but do ignore local override files
docker-compose.local.yml
docker-compose.dev.yml

# =============================================================================
# Editors
# =============================================================================

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains IDEs
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Logs
# =============================================================================

logs/
*.log
